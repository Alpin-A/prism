      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "prism-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT \n    am.last_updated AS time,\n    am.variant_id AS metric,\n    CASE WHEN e.n_users > 0 THEN am.n_events::float / e.n_users ELSE 0 END AS value\nFROM agg_metrics am\nJOIN (\n    SELECT variant_id, COUNT(DISTINCT user_id) AS n_users\n    FROM exposures\n    WHERE experiment_id = '$experiment'\n    GROUP BY variant_id\n) e ON e.variant_id = am.variant_id\nWHERE am.experiment_id = '$experiment'\nAND am.event_type = '$event_type'\nORDER BY time ASC",
          "refId": "A"
        }
      ],
      "title": "Conversion Rate by Variant",
      "type": "timeseries"
    },
