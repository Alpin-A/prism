          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n    NOW() AS time,\n    COUNT(DISTINCT me.user_id)::float / NULLIF(COUNT(DISTINCT e.user_id), 0) AS value\nFROM exposures e\nLEFT JOIN metric_events me \n    ON me.experiment_id = e.experiment_id \n    AND me.user_id = e.user_id\n    AND me.event_type = '$event_type'\nWHERE e.experiment_id = '$experiment'\nAND e.variant_id = 'treatment'",
          "refId": "A"
        }
      ],
